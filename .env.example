# Configuração da API de Produtos Complementares - Olist

# =============================================================================
# CONFIGURAÇÕES BÁSICAS
# =============================================================================

# Modo de desenvolvimento (true = usa CSVs locais, false = usa bancos externos)
DEVELOPMENT_MODE=true

# =============================================================================
# BANCO DE DADOS POSTGRESQL
# =============================================================================

# Configurações do PostgreSQL para armazenar candidatos complementares e logs
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=olist_recommendations
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# =============================================================================
# CACHE REDIS
# =============================================================================

# Configurações do Redis para cache de recomendações
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600

# =============================================================================
# ELASTICSEARCH
# =============================================================================

# Configurações do Elasticsearch para busca rápida de produtos
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_USE_SSL=false

# =============================================================================
# CONFIGURAÇÕES DA API
# =============================================================================

# Configurações JWT para autenticação
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# SISTEMA DE RECOMENDAÇÃO
# =============================================================================

# Configurações do algoritmo de produtos complementares
RECOMMENDATION_DEFAULT_LIMIT=10
RECOMMENDATION_MAX_LIMIT=50
COMPLEMENTARY_PRODUCTS_LIMIT=50

# Configurações do processamento batch
BATCH_PROCESSING_MONTHS=12
BATCH_MIN_COOCCURRENCE=5

# Configurações de rerank
RERANK_MARGIN_WEIGHT=0.3
RERANK_DIVERSITY_PENALTY=0.2

# =============================================================================
# CONFIGURAÇÕES LEGADAS (COMPATIBILIDADE)
# =============================================================================

# Configurações do sistema legado (ainda usadas por alguns endpoints)
DB_SERVER=localhost
DB_DATABASE=olist_db
DB_USERNAME=sa
DB_PASSWORD=YourPassword123!
DB_DRIVER=ODBC Driver 17 for SQL Server

# =============================================================================
# AMBIENTE E LOGGING
# =============================================================================

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Diretório dos dados CSV (para modo desenvolvimento)
DATA_PATH=ds/

# =============================================================================
# CONFIGURAÇÕES DE PRODUÇÃO
# =============================================================================

# Uncomment and configure for production deployment

# SSL/TLS
# USE_SSL=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# CORS
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# ALLOWED_METHODS=GET,POST,PUT,DELETE
# ALLOWED_HEADERS=*

# Rate Limiting
# MAX_REQUESTS_PER_MINUTE=60
# MAX_REQUESTS_PER_HOUR=1000

# Monitoring
# SENTRY_DSN=https://your-sentry-dsn-here
# DATADOG_API_KEY=your-datadog-api-key

# Database Connection Pooling
# POSTGRES_POOL_SIZE=20
# POSTGRES_MAX_OVERFLOW=30
# POSTGRES_POOL_TIMEOUT=30

# Redis Connection Pooling
# REDIS_POOL_SIZE=50
# REDIS_CONNECTION_TIMEOUT=5

# =============================================================================
# CONFIGURAÇÕES DE DESENVOLVIMENTO
# =============================================================================

# Configurações específicas para ambiente de desenvolvimento
# (estas são ignoradas se DEVELOPMENT_MODE=false)

# Simular latência de rede (em ms) para testes
# SIMULATE_NETWORK_LATENCY=0

# Usar dados de amostra reduzidos para testes rápidos
# USE_SAMPLE_DATA=false
# SAMPLE_DATA_SIZE=10000

# Debug de performance
# ENABLE_PERFORMANCE_LOGGING=true
# LOG_SLOW_QUERIES=true
# SLOW_QUERY_THRESHOLD=1000

# =============================================================================
# COMANDOS ÚTEIS PARA CONFIGURAÇÃO
# =============================================================================

# Para gerar uma nova JWT secret key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

# Para testar conexões de banco:
# psql -h localhost -p 5432 -U postgres -d olist_recommendations -c "SELECT 1;"
# redis-cli -h localhost -p 6379 ping
# curl -X GET "localhost:9200/_cluster/health"